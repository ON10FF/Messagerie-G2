<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.ui.MainController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 40;">

    <Label text="💬 Messagerie Association"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

    <Label text="Bienvenue dans votre espace de messagerie"
           style="-fx-font-size: 14px; -fx-text-fill: #aaaaaa;"/>

    <HBox alignment="CENTER" spacing="20">

        <Button text="Se connecter" onAction="#allerLogin"
                style="-fx-background-color: #e94560; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 12 30;
                       -fx-cursor: hand;"/>

        <Button text="S'inscrire" onAction="#allerRegister"
                style="-fx-background-color: transparent; -fx-text-fill: #e94560;
                       -fx-font-size: 14px; -fx-border-color: #e94560;
                       -fx-border-radius: 8; -fx-background-radius: 8;
                       -fx-padding: 12 30; -fx-cursor: hand;"/>
    </HBox>

    <!--  RG10 -->
    <Label fx:id="labelErreurReseau" text=""
           style="-fx-text-fill: #e94560; -fx-font-size: 13px;"/>

</VBox>